# TightandHard — environment variables
# Copy this file to .env (not .env.local) and fill in real values.
# NEVER commit the real .env to git.

# =========================================
# Database (MongoDB Atlas — free tier)
# =========================================
DATABASE_URL="mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/tightandhard?retryWrites=true&w=majority"

# =========================================
# Authentication (Clerk — free tier)
# =========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# =========================================
# AI chat (OpenAI)
# =========================================
OPENAI_API_KEY=sk-

# =========================================
# AI alt model + image generation (Replicate)
# =========================================
REPLICATE_API_TOKEN=r8_

# =========================================
# Memory / vector search (Pinecone — free tier)
# =========================================
PINECONE_API_KEY=
PINECONE_INDEX=tightandhard
PINECONE_ENVIRONMENT=

# =========================================
# Rate limiting (Upstash Redis — free tier)
# =========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =========================================
# Image uploads (Cloudinary — free tier; fallback when not using Replicate-generated)
# =========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# =========================================
# Payments (Stripe)
# =========================================
STRIPE_API_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# =========================================
# Voice (ElevenLabs)
# =========================================
ELEVENLABS_API_KEY=

# =========================================
# App URL (used by Stripe return_url)
# =========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
