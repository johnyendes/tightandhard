# Server Configuration
NODE_ENV=development
API_PORT=5002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Stable Diffusion Configuration
SD_API_URL=http://127.0.0.1:7860
SD_MODEL=RealisticVisionV60.safetensors
SD_STEPS=40
SD_CFG_SCALE=7.5
SD_BATCH_SIZE=1
SD_SAMPLER=DPM++ 2M Karras

# Database Configuration (TightandHard Backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tightandhard
DB_USER=tightandhard
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
EMAIL_FROM=noreply@tightandhard.com
EMAIL_FROM_NAME=TightandHard

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=24h

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./output
AWS_S3_BUCKET=tightandhard-models
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=us-east-1
CDN_URL=https://cdn.tightandhard.com

# Packaging Configuration
MAX_DOWNLOADS=5
DOWNLOAD_EXPIRY_DAYS=30
PACKAGE_RETENTION_DAYS=90
COMPRESSION_LEVEL=9

# Security
ENCRYPTION_KEY=your_encryption_key_here
RATE_LIMIT=100
RATE_LIMIT_WINDOW_MS=900000

# Generation Settings
DEFAULT_PERSONA=romantic_partner
OUTFIT_COUNT=15
IMAGE_QUALITY=high
GENERATION_TIMEOUT=120000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Stripe Integration (for purchase webhooks)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_WEBHOOK_ENDPOINT=/webhooks/stripe

# Replicate API (optional cloud SD)
REPLICATE_API_TOKEN=r8_your_replicate_token

# Base URL for download links
BASE_URL=https://api.tightandhard.com

# Admin Configuration
ADMIN_EMAIL=admin@tightandhard.com
ADMIN_PASSWORD=your_admin_password

# Feature Flags
ENABLE_IMAGE_GENERATION=true
ENABLE_BATCH_GENERATION=true
ENABLE_AUTO_PACKAGING=true
ENABLE_ANALYTICS=true

# Performance
WORKER_THREADS=4
CACHE_ENABLED=true
CACHE_TTL=3600