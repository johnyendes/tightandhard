{
  "name": "tightandhard-ai-model-generator",
  "version": "1.0.0",
  "description": "Automated AI Model Generation System for TightandHard.com",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "generate": "node scripts/generateModel.js",
    "batch-generate": "node scripts/batchGenerate.js",
    "package": "node scripts/packageModel.js",
    "cleanup": "node scripts/cleanup.js",
    "health": "node scripts/healthCheck.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "ai",
    "model-generation",
    "stable-diffusion",
    "tightandhard",
    "companion",
    "automation"
  ],
  "author": "TightandHard",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "joi": "^17.11.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "@types/node": "^20.10.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tightandhard/ai-model-generator.git"
  },
  "bugs": {
