{
  "name": "tightandhard-backend",
  "version": "1.0.0",
  "description": "TightandHard.com Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:with-repair": "AUTO_REPAIR_ENABLED=true node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:with-repair": "AUTO_REPAIR_ENABLED=true nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write &quot;src/**/*.js&quot;",
    "autofix": "npm run lint:fix && npm run format",
    "migrate": "node src/scripts/migrate.js"
  },
  "keywords": [
    "ai-companion",
    "emotional-intelligence",
    "character-simulation",
    "auto-repair",
    "self-healing",
    "monitoring"
  ],
  "author": "TightandHard Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "rate-limiter-flexible": "^2.4.1",
    "sequelize": "^6.32.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
