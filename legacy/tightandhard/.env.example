# TightandHard.com Environment Configuration

# Database Configuration
DB_NAME=ai_companion
DB_USER=th_user
DB_PASS=secure_password_change_me
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=change-this-to-secure-random-string

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Application Settings
MAX_MEMORY_IMPORTANCE=10
MIN_EMOTIONAL_WEIGHT=0
MAX_EMOTIONAL_WEIGHT=1
DEFAULT_BONDING_XP=10