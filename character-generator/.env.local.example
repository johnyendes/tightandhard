# TightandHard Character Generator — environment variables
# Copy to .env and fill in real values. Never commit real keys.

# =========================================
# Database (MongoDB Atlas)
# Separate database from the companion app!
# =========================================
DATABASE_URL="mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/tightandhard_generator?retryWrites=true&w=majority"

# =========================================
# Authentication (Clerk)
# Use the same Clerk application as the companion app so users share accounts.
# =========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# =========================================
# Image generation (Replicate)
# =========================================
REPLICATE_API_TOKEN=r8_
# Your Replicate username (used as destination for LoRA training models)
REPLICATE_USERNAME=

# =========================================
# Image hosting (Cloudinary — free tier)
# =========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tightandhard_models
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =========================================
# LLM helpers (OpenAI — prompt optimization, bio generation)
# =========================================
OPENAI_API_KEY=sk-

# =========================================
# Rate limiting (Upstash Redis — free tier)
# =========================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =========================================
# Billing (Stripe)
# =========================================
STRIPE_API_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# Stripe price IDs — create these once in Stripe dashboard for each tier.
# If left blank, /api/stripe falls back to inline price_data (fine for testing).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# =========================================
# App URL
# =========================================
NEXT_PUBLIC_APP_URL=http://localhost:3001
